{
  "name": "uptime-monitor",
  "version": "1.0.0",
  "description": "Self-hosted uptime monitoring + public status page. Pay once, own it forever.",
  "license": "MIT",
  "author": "Ben (bensblueprints)",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "desktop": "electron .",
    "dist": "npm run build && electron-builder --win",
    "test": "node test/smoke.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "nodemailer": "^6.9.16"
  },
  "build": {
    "appId": "com.bensblueprints.uptimemonitor",
    "productName": "Uptime Monitor",
    "files": [
      "electron/**/*",
      "server/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.7"
  }
}
